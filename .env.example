# iMissive Website Environment Variables
# Copy this file to .env.local and fill in the values

# ===========================================
# SMTP Configuration (for contact form)
# ===========================================

# SMTP server hostname (e.g., smtp.gmail.com, smtp.office365.com)
SMTP_HOST=

# SMTP server port (587 for TLS, 465 for SSL)
SMTP_PORT=587

# SMTP username (usually your email address)
SMTP_USER=

# SMTP password (use app-specific password if using Gmail)
SMTP_PASS=

# Email address to receive contact form submissions
CONTACT_EMAIL=info@imissive.com

# ===========================================
# Application Settings
# ===========================================

# Base URL of the website (without trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.imissive.com

# Enable/disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1

# ===========================================
# Optional: Analytics & Tracking
# ===========================================

# Google Analytics Measurement ID (e.g., G-XXXXXXXXXX)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ===========================================
# Optional: External Services
# ===========================================

# Add any additional service API keys here
# API_KEY_SERVICE_NAME=

# ===========================================
# Docker/Production Settings
# ===========================================

# Node environment (development, production)
NODE_ENV=production
